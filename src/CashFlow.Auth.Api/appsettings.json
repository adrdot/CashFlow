{
  "Jwt": {
    "Issuer": "CashFlow.Auth.Api",
    "Audience": "CashFlow.Web",
    "SigningKey": "dev-only-signing-key-change-me-1234567890",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Cognito": {
    "Enabled": false,
    "UserPoolId": "",
    "ClientId": "",
    "Region": "us-east-1",
    "ServiceUrl": "",
    "RequireMfa": false,
    "AuthenticationSource": "InMemoryFallback",
    "OAuth": {
      "Enabled": true
    }
  },
  "SecretsManager": {
    "Region": "us-east-1",
    "Prefix": "cashflow/",
    "EnableCaching": true,
    "CacheDurationMinutes": 5,
    "ServiceUrl": "",
    "PreferConfiguration": false
  },
  "RuntimeSecrets": {
    "Jwt:SigningKey": "Auth/JwtSigningKey"
  },
  "Kms": {
    "Region": "us-east-1",
    "DefaultKeyId": "alias/cashflow-default",
    "SecretsKeyId": "alias/cashflow-secrets",
    "StorageKeyId": "alias/cashflow-storage",
    "ServiceUrl": ""
  },
  "Secrets": {
    "Auth/JwtSigningKey": "dev-only-signing-key-change-me-1234567890",
    "Auth:ClientSecret": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
