{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AWS": {
    "Region": "us-east-1",
    "ServiceUrl": "",
    "AccessKey": "",
    "SecretKey": "",
    "LocalStackAccountId": "000000000000"
  },
  "Observability": {
    "PrometheusEnabled": true
  },
  "Security": {
    "RateLimitingEnabled": true,
    "GlobalPermitLimit": 200,
    "GlobalWindowSeconds": 60,
    "AuthLoginPermitLimit": 10,
    "AuthLoginWindowSeconds": 60
  },
  "CloudWatch": {
    "Enabled": false,
    "Region": "us-east-1",
    "ServiceUrl": "",
    "LogGroupPrefix": "/cashflow",
    "BatchSize": 10,
    "FlushPeriodSeconds": 5
  },
  "EventStore": {
    "ConnectionString": "",
    "HttpEndpoint": "",
    "SubscriptionGroupName": "cashflow-sns-relay",
    "StreamNamePrefix": "cashflow-",
    "HttpTimeoutSeconds": 30,
    "SubscriptionMonitorPollSeconds": 15,
    "SubscriptionBufferSize": 20,
    "BackwardPageSize": 50,
    "MaxReadPages": 20,
    "PersistentSubscriptionStream": "$all"
  },
  "Messaging": {
    "Enabled": false,
    "SnsTopicArn": "",
    "SqsQueueUrl": "",
    "DlqQueueUrl": "",
    "ServiceUrl": "",
    "Region": "us-east-1",
    "MaxPublishRetries": 5
  },
  "Transactions": {
    "PersistenceRetryAfterSeconds": 5
  },
  "Jwt": {
    "Issuer": "CashFlow.Auth.Api",
    "Audience": "CashFlow.Web",
    "SigningKey": "",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7,
    "ClockSkewSeconds": 30
  },
  "Cognito": {
    "Enabled": false,
    "UserPoolId": "",
    "ClientId": "",
    "Region": "us-east-1",
    "ServiceUrl": "",
    "RequireMfa": false,
    "AuthenticationSource": "InMemoryFallback",
    "ClockSkewMinutes": 1,
    "JwksTimeoutSeconds": 10
  }
}
