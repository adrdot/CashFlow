@page "/dashboard"
@rendermode InteractiveServer
@inject AuthApiClient AuthApiClient
@inject NavigationManager NavigationManager
@inject SessionStore SessionStore
@inject AuthenticatedSessionService AuthenticatedSessionService

<PageTitle>Dashboard</PageTitle>

@if (isLoading)
{
    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-2">Loading dashboard</h2>
            <p class="text-body-secondary mb-0">Validating your session...</p>
        </div>
    </div>
}
else if (currentSession is null)
{
    <div class="alert alert-warning" role="alert">
        Your session is no longer valid. Redirecting to sign in...
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-start">
                    <div>
                        <h2 class="h4 mb-1">Welcome, @currentSession.DisplayName</h2>
                        <p class="text-body-secondary mb-0">Signed in as @currentSession.Email</p>
                    </div>
                    <AuthLogoutButton OnLogout="HandleLogoutAsync" />
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3 class="h6 text-uppercase text-body-secondary">Session Expires</h3>
                    <p class="display-6 mb-0">@currentSession.ExpiresAtUtc.LocalDateTime.ToString("g")</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3 class="h6 text-uppercase text-body-secondary">Protected Area</h3>
                    <p class="mb-3">This route is only accessible with a valid JWT-backed session.</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-outline-primary" href="/cash-flow">Open cash flow screen</a>
                        <a class="btn btn-outline-success" href="/reports">Open consolidated report</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private StoredSession? currentSession;
    private bool isLoading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        currentSession = await AuthenticatedSessionService.RestoreSessionAsync();
        if (currentSession is null)
        {
            isLoading = false;
            NavigationManager.NavigateTo("/");
            return;
        }

        isLoading = false;
        StateHasChanged();
    }

    private async Task HandleLogoutAsync()
    {
        var storedSession = await SessionStore.LoadAsync();
        if (storedSession is not null)
        {
            await AuthApiClient.LogoutAsync(storedSession.Token);
        }

        await SessionStore.ClearAsync();
        NavigationManager.NavigateTo("/");
    }
}