{
  "ConnectionStrings": {
    "reporting-db": ""
  },
  "AWS": {
    "Region": "us-east-1",
    "ServiceUrl": "",
    "AccessKey": "",
    "SecretKey": "",
    "LocalStackAccountId": "000000000000"
  },
  "Observability": {
    "PrometheusEnabled": true
  },
  "Security": {
    "RateLimitingEnabled": true,
    "GlobalPermitLimit": 200,
    "GlobalWindowSeconds": 60,
    "AuthLoginPermitLimit": 10,
    "AuthLoginWindowSeconds": 60
  },
  "CloudWatch": {
    "Enabled": false,
    "Region": "us-east-1",
    "ServiceUrl": "",
    "LogGroupPrefix": "/cashflow",
    "BatchSize": 10,
    "FlushPeriodSeconds": 5
  },
  "Reporting": {
    "Redis": {
      "Enabled": false,
      "Configuration": ""
    },
    "Cache": {
      "CurrentDayTtlMinutes": 15,
      "ClosedDayTtlHours": 24
    }
  },
  "Messaging": {
    "SqsQueueUrl": "",
    "DlqQueueUrl": "",
    "ServiceUrl": "",
    "Region": "us-east-1",
    "MaxMessages": 10,
    "WaitTimeSeconds": 20,
    "VisibilityTimeoutSeconds": 30,
    "QueueMissingRetrySeconds": 10,
    "ErrorRetrySeconds": 5
  },
  "Jwt": {
    "Issuer": "CashFlow.Auth.Api",
    "Audience": "CashFlow.Web",
    "SigningKey": "",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7,
    "ClockSkewSeconds": 30
  },
  "Cognito": {
    "Enabled": false,
    "UserPoolId": "",
    "ClientId": "",
    "Region": "us-east-1",
    "ServiceUrl": "",
    "ClockSkewMinutes": 1,
    "JwksTimeoutSeconds": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
