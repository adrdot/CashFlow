{
  "ConnectionStrings": {
    "reporting-db": ""
  },
  "Reporting": {
    "Redis": {
      "Enabled": false,
      "Configuration": "localhost:6379"
    },
    "Cache": {
      "CurrentDayTtlMinutes": 15,
      "ClosedDayTtlHours": 24
    }
  },
  "Messaging": {
    "SqsQueueUrl": "",
    "DlqQueueUrl": "",
    "ServiceUrl": "",
    "Region": "us-east-1",
    "MaxMessages": 10,
    "WaitTimeSeconds": 20,
    "VisibilityTimeoutSeconds": 30
  },
  "Jwt": {
    "Issuer": "CashFlow.Auth.Api",
    "Audience": "CashFlow.Web",
    "SigningKey": "dev-only-signing-key-change-me-1234567890"
  },
  "Cognito": {
    "Enabled": false,
    "UserPoolId": "",
    "ClientId": "",
    "Region": "us-east-1",
    "ServiceUrl": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
