{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP requests / s (reporting)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"reporting-api\"}[1m])) or sum(rate(http_server_request_duration_seconds_count{exported_job=\"reporting-api\"}[1m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "title": "5xx error rate %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 * (sum(rate(http_server_request_duration_seconds_count{job=\"reporting-api\",http_response_status_code=~\"5..\"}[5m])) or sum(rate(http_server_request_duration_seconds_count{exported_job=\"reporting-api\",http_response_status_code=~\"5..\"}[5m]))) / clamp_min((sum(rate(http_server_request_duration_seconds_count{job=\"reporting-api\"}[5m])) or sum(rate(http_server_request_duration_seconds_count{exported_job=\"reporting-api\"}[5m]))), 1)",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "title": "Cached read p95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(reporting_read_duration_milliseconds_bucket{cache=\"hit\",outcome=\"success\"}[5m])) by (le))",
          "legendFormat": "p95 hit"
        }
      ]
    },
    {
      "title": "Uncached read p95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(reporting_read_duration_milliseconds_bucket{cache=\"miss\",outcome=\"success\"}[5m])) by (le))",
          "legendFormat": "p95 miss"
        }
      ]
    },
    {
      "title": "Cache hits / min",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 16 },
      "targets": [{ "expr": "sum(increase(reporting_cache_hits_total[5m]))" }]
    },
    {
      "title": "Cache misses / min",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 16 },
      "targets": [{ "expr": "sum(increase(reporting_cache_misses_total[5m]))" }]
    },
    {
      "title": "Export failures / min",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 16 },
      "targets": [{ "expr": "sum(increase(reporting_export_failures_total[5m]))" }]
    },
    {
      "title": "Projection failures / min",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 16 },
      "targets": [{ "expr": "sum(increase(reporting_messages_failures_total[5m]))" }]
    },
    {
      "title": "SQS visible messages",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "max(aws_sqs_approximate_number_of_messages_visible_average{dimension_QueueName=~\"cashflow-transaction-recorded.*\"})",
          "legendFormat": "visible"
        },
        {
          "expr": "max(aws_sqs_approximate_number_of_messages_not_visible_average{dimension_QueueName=~\"cashflow-transaction-recorded.*\"})",
          "legendFormat": "in flight"
        }
      ]
    },
    {
      "title": "Messages consumed / s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "sum(rate(reporting_messages_consumed_total[1m]))",
          "legendFormat": "consumed"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["cashflow", "reporting"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "title": "Reporting",
  "uid": "cashflow-reporting",
  "version": 1
}
